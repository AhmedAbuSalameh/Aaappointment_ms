<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox xmlns="http://javafx.com/javafx/11.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="appointmentschedulingsystem.appointmentschedulingsystem.UserDashboardController"
      spacing="14" style="-fx-background-color: linear-gradient(to bottom, #f8fafc, #eff6ff);">
    <padding><Insets top="20" right="20" bottom="20" left="20"/></padding>
    <children>
        <Label text="User Dashboard" style="-fx-text-fill: #0f172a; -fx-font-weight: bold;"><font><Font size="27"/></font></Label>
        <Label text="Available Appointment Slots" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
        <TableView fx:id="availableSlotsTable" prefHeight="220"
                   style="-fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #bfdbfe;
                          -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.12), 10, 0.05, 0, 4);">
            <columns>
                <TableColumn fx:id="slotDateColumn" text="Date" prefWidth="180"/>
                <TableColumn fx:id="slotTimeColumn" text="Time" prefWidth="180"/>
                <TableColumn fx:id="slotDurationColumn" text="Allowed Duration" prefWidth="180"/>
            </columns>
        </TableView>
        <HBox spacing="10">
            <children>
                <Button text="Book Selected Slot" onAction="#handleBookAppointment"
                        style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold;"/>
                <Button text="Refresh" onAction="#handleRefresh"
                        style="-fx-background-color: #e2e8f0; -fx-text-fill: #0f172a; -fx-background-radius: 10; -fx-font-weight: bold;"/>
                <Button text="Logout" onAction="#handleLogout"
                        style="-fx-background-color: #0f172a; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold;"/>
            </children>
        </HBox>
        <Label text="My Appointments" style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #334155;"/>
        <TableView fx:id="myAppointmentsTable" prefHeight="260"
                   style="-fx-background-radius: 14; -fx-border-radius: 14; -fx-border-color: #bfdbfe;
                          -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.12), 10, 0.05, 0, 4);">
            <columns>
                <TableColumn fx:id="dateColumn" text="Date" prefWidth="110"/>
                <TableColumn fx:id="timeColumn" text="Time" prefWidth="100"/>
                <TableColumn fx:id="durationColumn" text="Duration" prefWidth="120"/>
                <TableColumn fx:id="participantsColumn" text="Participants" prefWidth="110"/>
                <TableColumn fx:id="typeColumn" text="Type" prefWidth="160"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
            </columns>
        </TableView>
        <HBox spacing="10">
            <children>
                <Button text="Modify Selected" onAction="#handleModifyAppointment"
                        style="-fx-background-color: #0ea5e9; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold;"/>
                <Button text="Cancel Selected" onAction="#handleCancelAppointment"
                        style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold;"/>
            </children>
        </HBox>
    </children>
</VBox>

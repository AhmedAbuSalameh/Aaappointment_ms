<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<StackPane xmlns="http://javafx.com/javafx/11.0.1"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="appointmentschedulingsystem.appointmentschedulingsystem.SignupController"
           style="-fx-background-color: linear-gradient(to bottom right, #111827, #2563eb, #60a5fa);">
    <children>
        <VBox alignment="CENTER" spacing="15" maxWidth="390"
              style="-fx-background-color: rgba(255,255,255,0.97); -fx-background-radius: 18;
                     -fx-effect: dropshadow(gaussian, rgba(15,23,42,0.28), 22,0.15,0,8);">
            <padding><Insets top="34" right="34" bottom="34" left="34"/></padding>
            <children>
                <Label text="Create Gmail Account"><font><Font size="27"/></font></Label>
                <Label text="Use a real Gmail address to receive booking notifications"
                       style="-fx-text-fill: #475569; -fx-font-size: 13;" wrapText="true"/>
                <TextField fx:id="nameField" promptText="Full Name" prefHeight="42"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #cbd5e1; -fx-padding: 6 12;"/>
                <TextField fx:id="emailField" promptText="Gmail Address" prefHeight="42"
                           style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #cbd5e1; -fx-padding: 6 12;"/>
                <PasswordField fx:id="passwordField" promptText="Password" prefHeight="42"
                               style="-fx-background-radius: 10; -fx-border-radius: 10; -fx-border-color: #cbd5e1; -fx-padding: 6 12;"/>
                <Button text="Sign Up" prefWidth="240" prefHeight="42" onAction="#handleSignUp"
                        style="-fx-background-color: linear-gradient(to right, #0ea5e9, #2563eb); -fx-text-fill: white; -fx-background-radius: 10; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="Back to Login" prefWidth="240" prefHeight="38" onAction="#switchToLogin"
                        style="-fx-background-color: #eff6ff; -fx-text-fill: #1d4ed8; -fx-background-radius: 10; -fx-cursor: hand; -fx-font-weight: bold;"/>
            </children>
        </VBox>
    </children>
</StackPane>
